# Segredo usado para assinar os JWT (HS256). NUNCA versionar o valor real.
# Gere um novo com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Algoritmo de assinatura do JWT
ALGORITHM=HS256

# Tempo de expiração do access token (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tempo de expiração do authorization code (minutos)
AUTH_CODE_EXPIRE_MINUTES=10

# Tempo de expiração do refresh token (dias)
REFRESH_TOKEN_EXPIRE_DAYS=30

# URL de conexão com o banco (async). Dev: SQLite. Prod: PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./auth.db
